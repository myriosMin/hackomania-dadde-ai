# Your Open Payments wallet address (from https://wallet.interledger-test.dev/)
WALLET_ADDRESS=https://wallet.interledger-test.dev/<your-wallet-address>

# Key material from your wallet's API client settings
KEY_ID=<your-key-id>
# PRIVATE_KEY can be either:
# - PEM contents (including -----BEGIN...----- lines), or
# - an absolute/relative path to a PEM file, or
# - a base64-encoded PKCS#8 DER key
PRIVATE_KEY=<your-private-key>

# Recipient wallet address (for quote/outgoing payment demos)
RECEIVER_WALLET_ADDRESS=https://wallet.interledger-test.dev/<recipient-wallet-address>

# Monetary values are integers in minor units using sender wallet's asset scale.
# Example: with USD scale 2, 100 = $1.00
INCOMING_AMOUNT=100
QUOTE_SEND_AMOUNT=100

# Used by outgoing interactive grant flow
GRANT_REDIRECT_URI=http://localhost:3344/callback
GRANT_NONCE=<random-nonce>

# Set after step 3 (create-incoming-payment) - the incoming payment URL used as receiver in step 4
INCOMING_PAYMENT_URL=

# For continuing the interactive grant (set after step 5)
CONTINUE_ACCESS_TOKEN=
CONTINUE_URI=
INTERACT_REF=

# Final outgoing payment call (set after step 6 and step 4)
OUTGOING_ACCESS_TOKEN=
QUOTE_URL=

# ── New: read / lifecycle operations ──────────────────────────────────────────

# URL of a specific outgoing payment (output of step 07) — used by steps 09
OUTGOING_PAYMENT_URL=

# Incoming-payment access token (output of step 02) — reuse for steps 11-13
INCOMING_PAYMENT_ACCESS_TOKEN=

# Quote access token — from a quote grant (step 04 creates this internally)
QUOTE_ACCESS_TOKEN=

# Token lifecycle — set from any grant's access_token.manage + access_token.value
TOKEN_MANAGE_URL=
TOKEN_VALUE=
