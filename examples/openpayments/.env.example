# Your Open Payments wallet address (from https://wallet.interledger-test.dev/)
WALLET_ADDRESS=https://wallet.interledger-test.dev/<your-wallet-address>

# Key material from your wallet's API client settings
KEY_ID=<your-key-id>
PRIVATE_KEY=<absolute-path-to-private-key-pem>

# Recipient wallet address (for quote/outgoing payment demos)
RECEIVER_WALLET_ADDRESS=https://wallet.interledger-test.dev/<recipient-wallet-address>

# Monetary values are integers in minor units using sender wallet's asset scale.
# Example: with USD scale 2, 100 = $1.00
INCOMING_AMOUNT=100
QUOTE_SEND_AMOUNT=100

# Used by outgoing interactive grant flow
GRANT_REDIRECT_URI=http://localhost:3344/callback
GRANT_NONCE=<random-nonce>

# For continuing the interactive grant (set after step 5)
CONTINUE_ACCESS_TOKEN=
CONTINUE_URI=
INTERACT_REF=

# Final outgoing payment call (set after step 6 and step 4)
OUTGOING_ACCESS_TOKEN=
QUOTE_URL=
