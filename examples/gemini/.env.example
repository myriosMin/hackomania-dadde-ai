# Required for Gemini + ADK
GOOGLE_API_KEY=your_gemini_api_key

# Optional model overrides
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_ADK_MODEL=gemini-2.5-flash

# Optional for vision example
IMAGE_PATH=

# Optional for Langfuse tracing examples
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
